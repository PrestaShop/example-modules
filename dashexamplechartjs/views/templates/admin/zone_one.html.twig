{% trans_default_domain 'Module.Dashexamplechartjs.Admin' %}

<div class="panel dashexamplechartjs-card">
  <h3 class="panel-heading">
    <span class="material-icons">pie_chart</span>
    {{ 'Traffic sources'|trans }}
  </h3>
  <div class="panel-body">
    <p class="text-muted">
      {{ 'dashactivity equivalent — doughnut chart, rendered with Chart.js. Range: %from% → %to%'|trans({'%from%': dateFrom, '%to%': dateTo}) }}
    </p>
    <canvas id="dashexamplechartjs-doughnut" height="220" role="img" aria-label="{{ 'Traffic sources breakdown'|trans }}"></canvas>
    <script type="application/json" id="dashexamplechartjs-doughnut-data">
      {
        "labels": ["Direct", "Search engines", "Referral sites", "Social networks"],
        "values": [42, 31, 18, 9]
      }
    </script>
  </div>
</div>
